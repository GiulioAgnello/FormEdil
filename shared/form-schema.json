          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "optionsRef": "strumentiVerifica",
          "min": 1,
          "col": 12
        }
      ]
    },

    {
      "id": "partecipanti",
      "title": "Partecipanti",
      "description": "Massimo 25 lavoratori - indicare Nome, Cognome e Data di nascita",
      "fields": [
        {
          "name": "partecipanti",
          "label": "Partecipanti al corso",
          "type": "partecipantiTable",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "min": 1,
          "max": 25,
          "pasteEnabled": true,
          "itemFields": [
            {
              "name": "nome",
              "label": "Nome",
              "type": "text",
              "required": true
            },
            {
              "name": "cognome",
              "label": "Cognome",
              "type": "text",
              "required": true
            },
            {
              "name": "data_nascita",
              "label": "Data di nascita",
              "type": "date",
              "required": true
            }
          ]
