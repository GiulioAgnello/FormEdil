    {
      "id": "dichiarazioni",
      "title": "Dichiarazioni e privacy",
      "description": "Presa visione degli impegni e consenso al trattamento dati",
      "fields": [
        {
          "name": "ack_organizzazione",
          "label": "Dichiaro che il corso sarà organizzato ed erogato secondo l'Accordo Stato Regioni del 17/04/2025 e che docenti e partecipanti possiedono i requisiti previsti.",
          "type": "acknowledgment",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "col": 12
        },
        {
          "name": "ack_lingua",
          "label": "Dichiaro di aver verificato che eventuali partecipanti di origine straniera comprendono la lingua italiana, o sarà garantito interprete/mediatore culturale.",
          "type": "acknowledgment",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "col": 12
        },
        {
          "name": "ack_mandato",
          "label": "Dichiaro di aver avuto specifico mandato dal/i datore/i di lavoro delle imprese indicate.",
          "type": "acknowledgment",
          "required": true,
          "variants": ["ENTE"],
          "col": 12
        },
        {
          "name": "ack_impegni",
          "label": "Mi impegno a: trasmettere la richiesta almeno 15 gg prima; rispettare le indicazioni FORMEDIL; comunicare tempestivamente variazioni; trasmettere su richiesta registro presenze e verifiche entro 15 gg.",
          "type": "acknowledgment",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "col": 12
        },
        {
          "name": "ack_verifiche",
          "label": "Sono a conoscenza che FORMEDIL LECCE può effettuare verifiche in loco senza preavviso e revocare la collaborazione in caso di dichiarazioni non veritiere.",
          "type": "acknowledgment",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "col": 12
        },
        {
          "name": "ack_responsabilita",
          "label": "Dichiaro, consapevole della responsabilità penale ex artt. 75-76 DPR 445/2000, che quanto dichiarato corrisponde al vero.",
          "type": "acknowledgment",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "col": 12
        },
        {
          "name": "note",
          "label": "Eventuali note o comunicazioni",
          "type": "textarea",
          "required": false,
          "variants": ["IMPRESA", "ENTE"],
          "rows": 4,
          "col": 12
        },
        {
          "name": "privacy",
          "label": "Trattamento dei dati personali",
          "type": "radio",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "optionsRef": "privacy",
          "col": 12
        }
      ]
