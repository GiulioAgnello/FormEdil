        },
        {
          "name": "org_pec",
          "label": "PEC",
          "type": "email",
          "required": true,
          "variants": ["ENTE"],
          "validation": "email",
          "col": 4
        },

        {
          "name": "rpf_nome",
          "label": "Responsabile Progetto Formativo - Rag. Soc. / Cognome Nome",
          "type": "text",
          "required": true,
          "variants": ["ENTE"],
          "col": 12
        },
        {
          "name": "rpf_indirizzo",
          "label": "Indirizzo",
          "type": "text",
          "required": true,
          "variants": ["ENTE"],
          "col": 12
        },
        {
          "name": "rpf_telefono",
          "label": "Telefono",
          "type": "tel",
