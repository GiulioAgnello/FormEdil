        {
          "name": "sede_indirizzo",
          "label": "Sede svolgimento corso",
          "type": "text",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "placeholder": "Via e numero civico",
          "col": 12
        },
        {
          "name": "sede_luogo",
          "label": "Provincia / Comune / CAP",
          "type": "provinciaComuneCap",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "col": 12
        },
        {
          "name": "giornate",
          "label": "Giorni e orari del corso",
          "type": "repeater",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "min": 1,
          "itemFields": [
            {
              "name": "data",
              "label": "Data",
              "type": "date",
              "required": true
            },
            {
              "name": "ora_inizio",
              "label": "Dalle ore",
              "type": "time",
