{
  "version": "2.0.0",
  "title": "Richiesta collaborazione FORMEDIL Lecce - Art. 37 c.12 D.Lgs 81/2008",
  "meta": {
    "destinatario": "FORMEDIL LECCE - Via Belgio, 73100 Lecce",
    "oggetto": "Richiesta collaborazione - Art. 37 comma 12 D.Lgs 81/2008 s.m.i. - Accordo Stato Regioni del 17/04/2025",
    "privacyUrl": "https://www.formedillecce.it",
    "maxPartecipanti": 25,
    "maxDocenti": 4
  },

  "variants": {
    "IMPRESA": {
      "label": "Impresa edile",
      "subtitle": "Compila il modulo per attivare un corso per i tuoi dipendenti",
      "firme": ["Soggetto Formatore (impresa edile)"],
      "allegati": ["Copia documento di identità del datore di lavoro"]
    },
    "ENTE": {
      "label": "Ente di formazione",
      "subtitle": "",
      "firme": ["Soggetto Formatore che eroga il corso", "Impresa"],
      "allegati": [
        "Copia documento di identità del rappresentante legale dell'Ente di Formazione",
        "Copia documento di identità del datore di lavoro dell'impresa richiedente"
      ]
    }
  },

  "options": {
    "tipiCorso": [
      { "value": "generale", "label": "Corso di formazione generale" },
      {
        "value": "specifico",
        "label": "Corso di formazione specifico",
        "extra": "rischio"
      },
      { "value": "preposti", "label": "Corso di formazione per preposti" },
      { "value": "dirigenti", "label": "Corso di formazione per dirigenti" },
      {
        "value": "figure_sistema",
        "label": "Corso di formazione per figure di sistema"
      },
      {
        "value": "mansione",
        "label": "Corso di formazione specifico per la mansione di…"
      },
      { "value": "addestramento", "label": "Corso di addestramento specifico" },
      {
        "value": "attrezzature",
        "label": "Corso di formazione sulle attrezzature di lavoro"
      },
      { "value": "altro", "label": "Altro" }
    ],
    "rischio": [
      { "value": "basso", "label": "Rischio basso" },
      { "value": "medio", "label": "Rischio medio" },
      { "value": "alto", "label": "Rischio alto" }
    ],
    "modalita": [
      { "value": "presenza", "label": "Presenza fisica" },
      { "value": "videoconferenza", "label": "Video conferenza sincrona" },
      { "value": "elearning", "label": "E-Learning" }
    ],
    "strumentiVerifica": [
      { "value": "test", "label": "Test" },
      { "value": "colloquio", "label": "Colloquio" }
    ],
    "iscrizioneCassa": [
      { "value": "cassa_edile", "label": "Iscritta a Cassa Edile" },
      { "value": "edil_cassa", "label": "Iscritta a Edil Cassa" },
      { "value": "non_iscritta", "label": "NON iscritta a Casse Edili" }
    ],
    "privacy": [
      {
        "value": "autorizzo",
        "label": "Autorizzo FORMEDIL LECCE al trattamento dei dati"
      },
      {
        "value": "non_autorizzo",
        "label": "NON Autorizzo FORMEDIL LECCE al trattamento dei dati"
      }
    ]
  },

  "steps": [
    {
      "id": "anagrafica",
      "title": "Dati anagrafici",
      "description": "Datore di lavoro e azienda/impresa richiedente",
      "fields": [
        {
          "name": "datore_nome",
          "label": "Nome",
          "type": "text",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "col": 6
        },
        {
          "name": "datore_cognome",
          "label": "Cognome",
          "type": "text",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "col": 6
        },

        {
          "name": "azienda_ragione_sociale",
          "label": "Ragione Sociale",
          "type": "text",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "col": 12
        },
        {
          "name": "azienda_piva",
          "label": "Partita IVA",
          "type": "text",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "validation": "piva",
          "col": 6
        },
        {
          "name": "azienda_esercente",
          "label": "Esercente l'attività di",
          "type": "text",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "col": 6
        },
        {
          "name": "azienda_indirizzo",
          "label": "Indirizzo sede legale",
          "type": "text",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "placeholder": "Via e numero civico",
          "col": 12
        },
        {
          "name": "azienda_sede",
          "label": "Provincia / Comune / CAP",
          "type": "provinciaComuneCap",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "col": 12
        },
        {
          "name": "azienda_telefono",
          "label": "Telefono",
          "type": "tel",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "col": 4
        },
        {
          "name": "azienda_email",
          "label": "E-Mail",
          "type": "email",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "validation": "email",
          "col": 4
        },
        {
          "name": "azienda_pec",
          "label": "PEC",
          "type": "email",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "validation": "email",
          "col": 4
        },
        {
          "name": "azienda_ateco",
          "label": "Codice ATECO (Accordo Stato Regioni del 21/12/2011)",
          "type": "text",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "placeholder": "F (Costruzioni)",
          "col": 6
        },

        {
          "name": "iscrizione_cassa",
          "label": "Iscrizione a Casse Edili",
          "type": "radio",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "optionsRef": "iscrizioneCassa",
          "col": 12
        },
        {
          "name": "cassa_edile_provincia",
          "label": "Cassa Edile di (provincia)",
          "type": "text",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "condition": { "field": "iscrizione_cassa", "equals": "cassa_edile" },
          "col": 6
        },
        {
          "name": "cassa_edile_numero",
          "label": "N° iscrizione Cassa Edile",
          "type": "text",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "condition": { "field": "iscrizione_cassa", "equals": "cassa_edile" },
          "col": 6
        },
        {
          "name": "edil_cassa_provincia",
          "label": "Edil Cassa di (provincia)",
          "type": "text",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "condition": { "field": "iscrizione_cassa", "equals": "edil_cassa" },
          "col": 6
        },
        {
          "name": "edil_cassa_numero",
          "label": "N° iscrizione Edil Cassa",
          "type": "text",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "condition": { "field": "iscrizione_cassa", "equals": "edil_cassa" },
          "col": 6
        }
      ]
    },

    {
      "id": "corso",
      "title": "Indicazioni corso",
      "description": "Corso di formazione in materia di igiene e sicurezza del lavoro",
      "fields": [
        {
          "name": "riferimento_normativo",
          "label": "Riferimento normativo del corso",
          "type": "text",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "col": 12
        },

        {
          "name": "tipo_corso",
          "label": "Tipologia di intervento formativo",
          "type": "radio",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "optionsRef": "tipiCorso",
          "help": "Per ogni corso è necessario compilare un modulo.",
          "col": 12
        },
        {
          "name": "rischio_specifico",
          "label": "Livello di rischio",
          "type": "select",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "optionsRef": "rischio",
          "condition": { "field": "tipo_corso", "equals": "specifico" },
          "col": 6
        },
        {
          "name": "spec_figure",
          "label": "Specificare quale figura di sistema",
          "type": "text",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "condition": { "field": "tipo_corso", "equals": "figure_sistema" },
          "col": 12
        },
        {
          "name": "spec_mansione",
          "label": "Specificare quale mansione",
          "type": "text",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "condition": { "field": "tipo_corso", "equals": "mansione" },
          "col": 12
        },
        {
          "name": "spec_addestramento",
          "label": "Specificare l'addestramento",
          "type": "text",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "condition": { "field": "tipo_corso", "equals": "addestramento" },
          "col": 12
        },
        {
          "name": "spec_attrezzature",
          "label": "Specificare quale attrezzatura",
          "type": "text",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "condition": { "field": "tipo_corso", "equals": "attrezzature" },
          "col": 12
        },
        {
          "name": "spec_altro",
          "label": "Specificare",
          "type": "text",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "condition": { "field": "tipo_corso", "equals": "altro" },
          "col": 12
        },

        {
          "name": "modalita",
          "label": "Modalità di svolgimento",
          "type": "select",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "optionsRef": "modalita",
          "col": 6
        },
        {
          "name": "durata_dal",
          "label": "Durata complessiva - dal",
          "type": "date",
          "required": false,
          "variants": ["IMPRESA", "ENTE"],
          "col": 6
        },
        {
          "name": "durata_al",
          "label": "Durata complessiva - al",
          "type": "date",
          "required": false,
          "variants": ["IMPRESA", "ENTE"],
          "col": 6
        }
      ]
    },

