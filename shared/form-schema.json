      "description": "Docenti in possesso dei requisiti ASR 17/04/2025 (massimo 4)",
      "fields": [
        {
          "name": "docenti",
          "label": "Nominativi dei docenti",
          "type": "docentiTable",
          "required": true,
          "variants": ["IMPRESA", "ENTE"],
          "min": 1,
          "max": 4,
          "itemFields": [
            {
              "name": "nome",
              "label": "Nome",
              "type": "text",
              "required": true
            },
            {
              "name": "cognome",
              "label": "Cognome",
              "type": "text",
              "required": true
            },
            {
              "name": "luogo_nascita",
