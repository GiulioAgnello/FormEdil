              "type": "date",
              "required": true
            },
            {
              "name": "residenza",
              "label": "Residenza (via e città)",
              "type": "text",
              "required": true
            },
            {
              "name": "telefono",
              "label": "Telefono",
              "type": "tel",
              "required": true
            },
            {
              "name": "email",
              "label": "E-mail",
              "type": "email",
              "required": true,
              "validation": "email"
